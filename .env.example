GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

JOB_API_URL=https://remotive.com/api/remote-jobs
JOB_CATEGORY=software-dev
JOB_LIMIT=20

SCORE_STRONG=7
SCORE_MAYBE=4

RETRY_ATTEMPTS=3
RETRY_INITIAL_DELAY_SEC=1.0
RETRY_BACKOFF_FACTOR=2.0
HTTP_TIMEOUT_SEC=15

JOBS_CACHE_TTL_SEC=1800

LLM_BATCH_SIZE=5
LLM_MAX_CONCURRENT_BATCHES=3
LLM_MIN_INTERVAL_SEC=2.0
LLM_RATE_LIMIT_COOLDOWN_SEC=60.0
LLM_MAX_DESC_CHARS=600
